# development | production
INFRAMIND_ENVIRONMENT=development
INFRAMIND_DDB_TABLE=

# The product uses only read-only discovery roles. Required for production agent analysis.
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL_ID=
AZURE_SUBSCRIPTION_IDS=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_MODEL=
AZURE_OPENAI_API_VERSION=

# Entra ID / OIDC validation for the operator API.
INFRAMIND_ISSUER=
INFRAMIND_AUDIENCE=

# GitHub App or short-lived OAuth token is only required after an approved remediation should create a PR.
GITHUB_TOKEN=
GITHUB_REPOSITORY=
